{
  "name": "conversia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "next dev -p 3000",
    "build": "node scripts/vercel-build.mjs",
    "build:local": "prisma db push --accept-data-loss=false && prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio",
    "db:seed": "npx prisma db seed"
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@vercel/blob": "^2.3.0",
    "@vercel/edge-config": "^1.4.0",
    "bcryptjs": "^3.0.3",
    "ffmpeg-static": "^5.3.0",
    "next": "15.3.6",
    "opus-media-recorder": "^0.8.0",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10",
    "eslint": "^9",
    "eslint-config-next": "15.3.6",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.0"
  }
}
