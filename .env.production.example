# Copiar valores a Vercel → Project → Environment Variables (Production)
# Tras el primer deploy, actualizar NEXT_PUBLIC_APP_URL con la URL final https://...
#
# Este proyecto no usa NextAuth: la sesión es cookie propia (no hace falta NEXTAUTH_*).

DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# URL pública exacta del despliegue (sin barra final)
NEXT_PUBLIC_APP_URL="https://tu-proyecto.vercel.app"

PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

BLOB_READ_WRITE_TOKEN=""

META_APP_ID=""
WHATSAPP_APP_SECRET=""

# Mismo valor en Vercel que invoques en cron si añades uno
CRON_SECRET=""

SEED_PASSWORD=""
SEED_SUPER_ADMIN_EMAIL=""
