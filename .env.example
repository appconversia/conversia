# Base de datos (PostgreSQL / Neon) — migraciones: npm run db:migrate
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Edge Config (Vercel): conecta el store al proyecto y copia el ID de conexión
# Ver: Vercel → Storage → tu Edge Config (ej. dbconversia) → .env.local
EDGE_CONFIG=""

# URL pública de la app (ej: https://chat.tudominio.com)
NEXT_PUBLIC_APP_URL=""

# Pusher (tiempo real) - crea app en pusher.com
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Vercel Blob (almacenamiento de imágenes)
BLOB_READ_WRITE_TOKEN=""

# Meta App ID (opcional, para cambiar foto de perfil de negocio)
# Configurar en developers.facebook.com → Tu app
META_APP_ID=""

# WhatsApp App Secret (recomendado en producción, verificación de firma del webhook)
WHATSAPP_APP_SECRET=""

# Seed (opcional)
SEED_PASSWORD=""
SEED_SUPER_ADMIN_EMAIL=""
