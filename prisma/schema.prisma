generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon: URL sin pooler para migraciones (evita P1002 advisory lock en el pooler)
  directUrl = env("DIRECT_URL")
}

model Plan {
  id                       String   @id @default(cuid())
  name                     String
  slug                     String   @unique
  maxUsers                 Int      @default(5)
  sortOrder                Int      @default(0)
  /// Precio mensual en centavos USD (ej. 4900 = US$49.00)
  priceUsdCents            Int      @default(0)
  /// Conversaciones incluidas por periodo de facturación
  includedConversations    Int      @default(100)
  /// Tamaño de cada pack extra (p. ej. 1000 conversaciones)
  extraPackConversations   Int      @default(1000)
  /// Precio por pack extra en centavos USD (p. ej. 1500 = US$15.00)
  extraPackPriceUsdCents     Int      @default(1500)
  tagline                  String?  @db.Text
  tenants                  Tenant[]
}

enum BillingStatus {
  trial
  active
  past_due
  suspended
}

model Tenant {
  id                     String         @id @default(cuid())
  name                   String
  slug                   String         @unique
  planId                 String?
  plan                   Plan?          @relation(fields: [planId], references: [id], onDelete: SetNull)
  active                 Boolean        @default(true)
  billingStatus          BillingStatus  @default(trial)
  subscriptionStartAt    DateTime?
  subscriptionEndAt      DateTime?
  /// Inicio del mes calendario usado para el conteo de conversaciones del periodo
  usagePeriodMonthStart  DateTime?
  conversationsInPeriod Int           @default(0)
  /// Packs extra comprados (cada pack suma plan.extraPackConversations)
  extraConversationPacks Int           @default(0)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  users                  User[]
  appConfigs             AppConfig[]
  conversationTags       ConversationTag[]
  contacts               Contact[]
  conversations          Conversation[]
  categories             Category[]
  botFlows               BotFlow[]
  leads                  Lead[]
  botLogs                BotLog[]
  payments               PaymentRecord[]

  @@index([slug])
  @@index([billingStatus])
  @@index([subscriptionEndAt])
}

enum PaymentRecordStatus {
  pending
  paid
  failed
  expired
}

model PaymentRecord {
  id               String              @id @default(cuid())
  tenantId         String
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amountUsdCents   Int
  currency         String                @default("USD")
  status           PaymentRecordStatus   @default(pending)
  /// subscription | extra_pack | manual
  type             String
  description      String?
  boldLinkId       String?
  checkoutUrl      String?               @db.Text
  reference        String?               @unique
  packCount        Int?
  createdAt        DateTime              @default(now())
  paidAt           DateTime?

  @@index([tenantId])
  @@index([status])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

enum UserRole {
  super_admin // Plataforma (tenantId null) o máximo en tenant
  admin
  colaborador
  sistema
}

model User {
  id                      String                      @id @default(cuid())
  email                   String                      @unique
  password                String
  name                    String?
  phone                   String?
  role                    UserRole                    @default(colaborador)
  active                  Boolean                     @default(true)
  tenantId                String?
  tenant                  Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  sessions                Session[]
  messagesSent            Message[]                   @relation("MessageSender")
  participantOf           ConversationParticipant[]
  conversationsAssigned   Conversation[]              @relation("ConversationAssignment")

  @@index([tenantId])
}

enum ConversationChannel {
  direct
  bot
  group
}

model ConversationTag {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  isSystem       Boolean        @default(false)
  order          Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversations  Conversation[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([order])
}

model Contact {
  id            String         @id @default(cuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone         String
  name          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  messagesSent  Message[]

  @@unique([tenantId, phone])
  @@index([tenantId])
}

model Conversation {
  id                     String                 @id @default(cuid())
  tenantId               String
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt              DateTime               @default(now())
  channel                ConversationChannel    @default(direct)
  contactId              String?
  contact                Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  groupId                String?
  groupName              String?
  handoffRequestedAt     DateTime?
  assignedToId           String?
  assignedTo             User?                  @relation("ConversationAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)
  restricted             Boolean                @default(false)
  lastReadAt             DateTime?
  lastProductSentForBot  String?
  pendingWelcomeCtaText  String?                @db.Text
  pendingWelcomeCtaMsgId String?
  participants           ConversationParticipant[]
  messages               Message[]
  botBatches             BotBatch[]
  conversationTagId      String?
  conversationTag        ConversationTag?       @relation(fields: [conversationTagId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([conversationTagId])
  @@index([channel])
  @@index([assignedToId])
  @@index([contactId])
  @@index([groupId])
  @@unique([groupId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id                  String        @id @default(cuid())
  conversationId      String
  senderId            String?
  senderContactId     String?
  content             String
  type                MessageType   @default(text)
  mediaUrl            String?
  mediaFilename       String?
  status              MessageStatus @default(sent)
  whatsappMessageId   String?       @unique
  replyToMessageId    String?
  createdAt           DateTime      @default(now())
  conversation        Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender              User?         @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  senderContact       Contact?      @relation(fields: [senderContactId], references: [id], onDelete: SetNull)
  batchItems          BotBatchMessage[]

  @@index([conversationId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
}

enum MessageType {
  text
  image
  video
  audio
  document
  sticker
}

enum MessageStatus {
  sent
  delivered
  read
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model AppConfig {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
}

model Lead {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone            String
  name             String?
  productInterest  String?
  interestLevel    String?
  priority         String?
  status           String   @default("Pendiente")
  notes            String?  @db.Text
  conversationId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId])
  @@index([phone])
  @@index([status])
  @@index([createdAt])
}

model Category {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([tenantId])
  @@index([order])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String   @db.Text
  price           Decimal  @db.Decimal(12, 2)
  stock           Int      @default(0)
  available       Boolean  @default(true)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  characteristics String?  @db.Text
  photos          String?  @db.Text
  videos          String?  @db.Text
  order           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([order])
  @@index([available])
  @@index([categoryId])
}

model BotFlow {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  flowJson    String   @db.Text
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([isActive])
}

model BotBatch {
  id             String       @id @default(cuid())
  conversationId String
  readyAt        DateTime
  status         String       @default("pending")
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages       BotBatchMessage[]

  @@index([conversationId])
  @@index([status, readyAt])
}

model BotBatchMessage {
  id        String   @id @default(cuid())
  batchId   String
  messageId String
  order     Int      @default(0)
  batch     BotBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([batchId, messageId])
  @@index([batchId])
}

model BotLog {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  level           String
  stage           String
  message         String   @db.Text
  conversationId  String?
  contactId       String?
  phone           String?
  metadata        String?  @db.Text
  error           String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([level])
  @@index([stage])
  @@index([conversationId])
}
